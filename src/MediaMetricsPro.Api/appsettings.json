{
  "ConnectionStrings": {
    "DefaultConnectionString": "Server=#DATABASE_Server#;Port=#PORT#;Database=#DATABASE#;User Id=#DATABASE_USER#;Password=#DATABASE_PASS#;Timeout=15;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}